        <input value="{{ cName }}" onInput="{{ setCName }}" placeholder="your name" style="min-height:58px; padding:0 20px; font-family:inherit; font-size:17px; font-weight:500; color:#16203A; background:#FBFCFE; border:2px solid #DCE3EF; border-radius:16px; outline:none; width:100%;" style-focus="border-color:#2F57E6">
