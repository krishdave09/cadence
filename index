          <button onClick="{{ goWaitlist }}" style="background:none; border:none; cursor:pointer; font-family:inherit; font-size:15px; font-weight:500; color:#C2CFE4; padding:0;">Join the waitlist</button>
          <a href="mailto:cadencehealthteam@gmail.com" style="font-size:15px; font-weight:600; color:#7CF0B7; text-decoration:none;">cadencehealthteam@gmail.com</a>
        </div>
