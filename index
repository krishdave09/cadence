      <div style="position:relative; width:312px; height:636px; background:#EEF3FB; border-radius:46px; box-shadow:0 40px 80px rgba(28,46,92,0.34), 0 0 0 10px #11182B, 0 0 0 12px #2A3450; overflow:hidden; animation:cadFloat 7s ease-in-out infinite;">
