    </div>
    <div style="border-top:1px solid #243355;"><div style="max-width:1200px; margin:0 auto; padding:22px 32px; display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;"><span style="font-size:14px; color:#6E7E9C;">© 2026 cadence</span><span style="font-size:14px; color:#6E7E9C;">*not a medical device. cadence does not provide medical advice, nor does it change perscriptions beyond what neurologists allow.</span></div></div>
  </div>

</div>
</x-dc>
<script type="text/x-dc" data-dc-script data-props="{&quot;$preview&quot;:{&quot;width&quot;:1200,&quot;height&quot;:900},&quot;accent&quot;:{&quot;editor&quot;:&quot;color&quot;,&quot;default&quot;:&quot;#2F57E6&quot;,&quot;tsType&quot;:&quot;string&quot;,&quot;options&quot;:[&quot;#2F57E6&quot;,&quot;#1F8A5B&quot;,&quot;#6E4FD8&quot;,&quot;#16203A&quot;]}}">
class Component extends DCLogic {
  state = { page: 'home', email: '', submitted: false, menuOpen: false, cName: '', cEmail: '', cMsg: '', cTopic: 'general', cSent: false };

  go(page) {
    this.setState({ page, menuOpen: false });
    try { window.scrollTo(0, 0); } catch (e) {}
  }

  componentDidMount() {
    this._revealEls = [];
    try {
      this._io = new IntersectionObserver((entries) => {
        for (const en of entries) {
          if (en.isIntersecting) this._revealNow(en.target);
        }
      }, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
    } catch (e) { this._io = null; }
    this._onScroll = () => this._checkReveals();
    window.addEventListener('scroll', this._onScroll, { passive: true });
    window.addEventListener('resize', this._onScroll, { passive: true });
    // safety net: rect-based check on a timer, in case IO never fires
    this._revealTimer = setInterval(() => this._checkReveals(), 700);
    // absolute safety net: on mobile, viewport-height quirks (address bar show/hide) can make a
    // section never satisfy the "in view" check; force everything visible after a few seconds
    // so nothing can stay permanently blank.
    this._revealForceTimer = setTimeout(() => {
      if (!this._revealEls) return;
      this._revealEls.forEach((el) => { if (el.isConnected) this._revealNow(el); });
      this._revealEls = [];
    }, 4000);
    this.revealSetup();
  }

  componentDidUpdate() { this.revealSetup(); }

  componentWillUnmount() {
    if (this._io) this._io.disconnect();
    window.removeEventListener('scroll', this._onScroll);
    window.removeEventListener('resize', this._onScroll);
    if (this._revealTimer) clearInterval(this._revealTimer);
    if (this._revealForceTimer) clearTimeout(this._revealForceTimer);
  }

  _revealNow(el) {
    el.setAttribute('data-reveal', 'in');
    if (this._io) { try { this._io.unobserve(el); } catch (e) {} }
  }

  _checkReveals() {
    if (!this._revealEls || !this._revealEls.length) return;
    const vh = window.innerHeight || 800;
    this._revealEls = this._revealEls.filter((el) => {
      if (!el.isConnected) return false;
      if (el.getAttribute('data-reveal') === 'in') return false;
      if (el.getBoundingClientRect().top < vh - 60) { this._revealNow(el); return false; }
      return true;
    });
  }

  revealSetup() {
    if (!this._revealEls) return;
    const vh = window.innerHeight || 800;
    // elements already on-screen at mount get a CSS *keyframe animation* instead of the
    // transition-based reveal: a keyframe animation always plays its "from" state once applied
    // to a freshly-styled element, whereas a transition needs the browser to actually paint the
    // hidden frame before flipping to visible, which races with IO's near-instant first callback
    // for anything already in view, that this used to lose, hence the top section never animated.
    const tag = (el, delay) => {
      if (el.getBoundingClientRect().top < vh - 60) {
        el.style.animation = 'cadReveal 0.85s cubic-bezier(0.22,0.61,0.36,1) ' + delay + 's both';
        el.setAttribute('data-reveal', 'in');
        return;
      }
      el.setAttribute('data-reveal', '');
      el.style.transitionDelay = delay + 's';
      this._revealEls.push(el);
      if (this._io) { try { this._io.observe(el); } catch (e) {} }
    };
    const kids = document.querySelectorAll('[data-site-root] > div');
    let i = 0;
    kids.forEach((el, idx) => {
      if (idx === 0) return; // sticky nav
      if (el.hasAttribute('data-reveal')) return;
      tag(el, Math.min(i * 0.06, 0.3));
      i++;
    });
    // staggered card-level reveals inside grids, on every page
    const cards = document.querySelectorAll('[data-site-root] [data-stack] > *, [data-site-root] [data-quad] > *, [data-site-root] [data-roadmap-row]');
    cards.forEach((el) => {
      if (el.hasAttribute('data-reveal')) return;
      const sib = el.parentElement ? Array.prototype.indexOf.call(el.parentElement.children, el) : 0;
      tag(el, Math.min(sib * 0.09, 0.45));
    });
  }

  renderVals() {
    const accent = this.props.accent ?? '#2F57E6';
    const page = this.state.page;
    const submitted = this.state.submitted;

    const nav = [
      { key: 'story', label: 'Our Story' },
      { key: 'how', label: 'How It Works' },
      { key: 'tech', label: 'Technology' },
      { key: 'roadmap', label: 'Roadmap' },
      { key: 'team', label: 'Team' },
    ];
    const navLinks = nav.map(n => ({
      key: n.key, label: n.label,
      onClick: () => this.go(n.key),
      color: page === n.key ? '#16203A' : '#3A4A66',
      weight: page === n.key ? 700 : 600,
    }));

    const CONTACT_EMAIL = 'cadencehealthteam@gmail.com';

    // ---- interactive charts ----
    const faB = this.state.faBudget ?? 2.5;
    const cadPts = [[0, 0], [0.5, 10], [1, 21], [1.5, 29], [2, 31], [2.5, 35], [3, 39], [3.5, 44], [4, 48], [4.5, 52], [5.4, 57]];
    const basePts = [[0, 0], [0.33, 8], [0.8, 13.5], [1.3, 18], [1.8, 23.5], [2.3, 30], [3.1, 38], [4, 47], [4.9, 55], [5.4, 58]];
    const interpPts = (pts, x) => {
      if (x <= pts[0][0]) return pts[0][1];
      for (let i = 1; i < pts.length; i++) {
        if (x <= pts[i][0]) {
          const a = pts[i - 1], b = pts[i];
          return a[1] + (b[1] - a[1]) * (x - a[0]) / (b[0] - a[0]);
        }
      }
      return pts[pts.length - 1][1];
    };
    const faCad = interpPts(cadPts, faB);
    const faBase = interpPts(basePts, faB);
    const pctToY = p => Math.round(330 - (p / 60) * 290);

    const proteinAmt = this.state.pkProteinAmt ?? 0; // 0-100
    const doseSize = this.state.pkDoseSize ?? 50; // 0-100, 50 = normal
    const t = proteinAmt / 100;
    const normalNums = [60,308,255,308,270,308,280,100,300,94,320,88,345,195,368,200,385,204,395,115,415,110,445,104,490,185,530,238,570,285,620,302,660,306];
    const proteinNums = [60,308,255,308,270,308,280,100,300,94,320,88,345,197,368,204,390,210,405,152,428,144,452,136,480,190,504,238,548,288,620,304,660,307];
    const cmds = ['M','L','C','C','C','C'];
    const doseScale = 1 + (doseSize - 50) / 50 * 0.28; // taller peaks with a bigger dose
    const baseline = 308;
    const lerped = normalNums.map((n, i) => {
      const v = n + (proteinNums[i] - n) * t;
      // scale the peak-defining y-values (odd indices) around the baseline by dose size
      if (i % 2 === 1 && v < baseline - 4) return baseline - (baseline - v) * doseScale;
      return v;
    });
    const n = lerped;
    const recoveryPeakY = Math.round(baseline - (baseline - 150) * doseScale);
    const recoveryMidY = Math.round(baseline - (baseline - 150) * doseScale + 40);
    const pkPathLerp = `M${n[0]},${n[1]} L${n[2]},${n[3]} C${n[4]},${n[5]} ${n[6]},${n[7]} ${n[8]},${n[9]} C${n[10]},${n[11]} ${n[12]},${n[13]} ${n[14]},${n[15]} C${n[16]},${n[17]} ${n[18]},${n[19]} ${n[20]},${n[21]} C${n[22]},${n[23]} ${n[24]},${n[25]} ${n[26]},${n[27]} C${n[28]},${n[29]} ${n[30]},${n[31]} ${n[32]},${n[33]} C688,307 702,${recoveryMidY} 720,${recoveryPeakY} C734,${recoveryPeakY - 18} 742,${recoveryPeakY - 10} 748,${recoveryPeakY}`;
    const pkOffXLerp = Math.round(528 + (504 - 528) * t);
    const pkOffWLerp = Math.round(132 + (156 - 132) * t);
    const pkNudgeXLerp = Math.round(502 + (478 - 502) * t);
    const pkNudgeYBase = 204 + (198 - 204) * t;
    const pkNudgeYLerp = Math.round(baseline - (baseline - pkNudgeYBase) * doseScale);
    const protein = proteinAmt >= 50;

    const ladderSel = this.state.ladderSel;
    const ladderStories = [
      { title: 'one clinic\u2019s data:', note: '0.83 when trained on some patients and scored on others from the same clinic. strong, but it only proves the model works for people who look like its training data.' },
      { title: 'a second clinic\u2019s patients:', note: 'the same model drops to 0.60 on a cohort collected by a different group, with different sensors and protocols. this is the fall most teams never test for, and the number we went looking for.' },
      { title: 'trained on both:', note: 'mixing both clinics\u2019 data recovers 0.86, scored on held-out patients the model has never seen. every production model now trains on multiple cohorts because of this result.' },
    ];
    const ladderPick = ladderSel == null ? null : ladderStories[ladderSel];

    const fzPos = this.state.fzPos ?? 30;
    const fzX = Math.round(40 + (fzPos / 100) * 920);
    let fzStatus = 'steady walking: a strong, regular rhythm.';
    if (fzX >= 690) fzStatus = 'the freeze: the feet have stopped. the cue fired about 1.25 seconds before this moment.';
    else if (fzX >= 610) fzStatus = 'cadence has warned: the ankle cue is pulsing a rhythm to step to.';
    else if (fzX >= 550) fzStatus = 'the stride shortens: the walking rhythm is starting to crumble.';

    return {
      accent,
      navLinks,
      menuOpenStr: this.state.menuOpen ? 'true' : 'false',
      toggleMenu: () => this.setState(s => ({ menuOpen: !s.menuOpen })),
      isHome: page === 'home', isHow: page === 'how', isTech: page === 'tech',
      isStory: page === 'story', isRoadmap: page === 'roadmap', isTeam: page === 'team',
      isContact: page === 'contact', isWaitlist: page === 'waitlist',
      showWaitlistBand: page !== 'waitlist',
      goHome: () => this.go('home'), goHow: () => this.go('how'), goTech: () => this.go('tech'),
      goStory: () => this.go('story'), goRoadmap: () => this.go('roadmap'), goTeam: () => this.go('team'),
      goContact: () => this.go('contact'), goWaitlist: () => this.go('waitlist'),

      email: this.state.email,
      setEmail: (e) => this.setState({ email: e.target.value, submitted: false }),
      submit: () => { if (this.state.email.trim()) this.setState({ submitted: true }); },
      ctaLabel: submitted ? "You're on the list" : 'Join the waitlist',
      ctaNote: submitted ? "Thanks, we'll be in touch soon." : 'We respect your privacy. Health data stays yours.',

      contactEmail: CONTACT_EMAIL,

      // interactive charts
      faBudget: faB,
      faVal: faB.toFixed(1),
      setFaBudget: (e) => this.setState({ faBudget: parseFloat(e.target.value) }),
      faMarkerX: Math.round(70 + (faB / 5.5) * 610),
      faCadY: pctToY(faCad),
      faBaseY: pctToY(faBase),
      faCadPct: Math.round(faCad) + '%',
      faBasePct: Math.round(faBase) + '%',
      pkProteinAmt: proteinAmt,
      pkDoseSize: doseSize,
      pkProteinLabel: proteinAmt <= 15 ? 'no protein' : (proteinAmt >= 70 ? 'protein-heavy lunch' : 'moderate protein'),
      pkDoseLabel: doseSize < 45 ? 'lower dose' : (doseSize > 55 ? 'higher dose' : 'usual dose'),
      pkProteinOptions: [
        { key: 'none', val: 0, label: 'no protein' },
        { key: 'mod', val: 45, label: 'moderate' },
        { key: 'high', val: 90, label: 'protein-heavy' },
      ].map(o => ({
        key: o.key, label: o.label,
        onClick: () => this.setState({ pkProteinAmt: o.val }),
        active: Math.abs(proteinAmt - o.val) < 15,
        bg: Math.abs(proteinAmt - o.val) < 15 ? '#16203A' : '#fff',
        color: Math.abs(proteinAmt - o.val) < 15 ? '#fff' : '#3A4A66',
        border: Math.abs(proteinAmt - o.val) < 15 ? '#16203A' : '#DCE3EF',
      })),
      pkDoseOptions: [
        { key: 'low', val: 25, label: 'lower dose' },
        { key: 'usual', val: 50, label: 'usual dose' },
        { key: 'high', val: 80, label: 'higher dose' },
      ].map(o => ({
        key: o.key, label: o.label,
        onClick: () => this.setState({ pkDoseSize: o.val }),
        active: Math.abs(doseSize - o.val) < 13,
        bg: Math.abs(doseSize - o.val) < 13 ? '#16203A' : '#fff',
        color: Math.abs(doseSize - o.val) < 13 ? '#fff' : '#3A4A66',
        border: Math.abs(doseSize - o.val) < 13 ? '#16203A' : '#DCE3EF',
      })),
      pkPath: pkPathLerp,
      pkOffX: pkOffXLerp,
      pkOffW: pkOffWLerp,
      pkNudgeX: pkNudgeXLerp,
      pkNudgeY: pkNudgeYLerp,
      pkNudgeLabelY: pkNudgeYLerp - 26,
      pkNoteTitle: protein ? 'the protein effect:' : 'how to read it:',
      pkNote: protein
        ? 'protein competes with levodopa for absorption, so the afternoon dose lands later and lower, and the off period starts almost an hour earlier. the rise on the right is the evening dose kicking in and recovery beginning. cadence sees the meal in the log and adjusts the forecast the same day.'
        : 'the blue line is your medication working; the red shaded zones are off periods, where it isn\u2019t. the green dot is cadence acting early, while there\u2019s still time for the next dose to land before the crossing.',
      ladderClick0: () => this.setState({ ladderSel: 0 }),
      ladderClick1: () => this.setState({ ladderSel: 1 }),
      ladderClick2: () => this.setState({ ladderSel: 2 }),
      ladderTitle: ladderPick ? ladderPick.title : 'how to read it:',
      ladderNote: ladderPick ? ladderPick.note : '1.0 is a perfect score, 0.5 is a coin flip. the middle bar is the uncomfortable one: a model that aces its home dataset can stumble on patients from a different clinic. the right bar is the fix, and the reason we train on more than one.',
      fzPos,
      setFzPos: (e) => this.setState({ fzPos: parseFloat(e.target.value) }),
      fzCursorX: fzX,
      fzStatus,
      cName: this.state.cName,
      cEmail: this.state.cEmail,
      cMsg: this.state.cMsg,
      setCName: (e) => this.setState({ cName: e.target.value, cSent: false }),
      setCEmail: (e) => this.setState({ cEmail: e.target.value, cSent: false }),
      setCMsg: (e) => this.setState({ cMsg: e.target.value, cSent: false }),
      sendMessage: () => {
        const { cName, cEmail, cMsg } = this.state;
        if (!cEmail.trim() || !cMsg.trim()) { this.setState({ cSent: 'missing' }); return; }
        const subject = encodeURIComponent('cadence, note from ' + (cName.trim() || cEmail.trim()));
        const body = encodeURIComponent(cMsg + '\n\n, ' + (cName.trim() ? cName.trim() + ' · ' : '') + cEmail.trim());
        try { window.open('mailto:' + CONTACT_EMAIL + '?subject=' + subject + '&body=' + body, '_self'); } catch (e) {}
        this.setState({ cSent: true });
      },
      sendLabel: this.state.cSent === true ? 'opening your email app…' : 'send message',
      sendNote: this.state.cSent === 'missing' ? 'please add your email and a message.' : (this.state.cSent === true ? "we'll reply within two business days." : ''),
    };
  }
}
</script>
