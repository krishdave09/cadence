            <div style="height:21%; background:#E08A8A; border-radius:12px 12px 4px 4px;"></div>
          </div>
          <div onClick="{{ ladderClick2 }}" style="flex:1; display:flex; flex-direction:column; justify-content:flex-end; height:100%; cursor:pointer; transition:transform 0.18s;" style-hover="transform:translateY(-4px)">
            <div style="font-size:22px; font-weight:800; color:#15724A; text-align:center; margin-bottom:8px;">0.86</div>
