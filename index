  <!-- THE HONEST TEST -->
  <div style="max-width:1200px; margin:0 auto; padding:84px 32px 10px;">
    <div style="display:grid; grid-template-columns:1.1fr 0.9fr; gap:56px; align-items:center;" data-stack="1">
      <div style="background:#fff; border:1px solid #ECF0F7; border-radius:26px; padding:30px 30px 24px; box-shadow:0 16px 38px rgba(28,46,92,0.06);">
        <div style="font-size:15px; font-weight:800; color:#16203A; margin-bottom:2px;">freeze detection accuracy (AUC), the generalization ladder</div>
        <div style="font-size:13px; font-weight:600; color:#8A96B0; margin-bottom:22px;">0.5 = coin flip · every bar scored on patients the model never saw · <span style="color:#2F57E6; font-weight:700;">tap a bar for its story</span></div>
        <div style="display:flex; align-items:flex-end; gap:26px; height:240px; padding:0 6px;">
