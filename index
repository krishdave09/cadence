      <div style="display:flex; gap:54px; flex-wrap:wrap;">
        <div style="display:flex; flex-direction:column; gap:12px; align-items:flex-start;">
          <span style="font-size:13px; font-weight:700; letter-spacing:1px; color:#5E6E8C;">LEARN</span>
          <button onClick="{{ goStory }}" style="background:none; border:none; cursor:pointer; font-family:inherit; font-size:15px; font-weight:500; color:#C2CFE4; padding:0;">Our story</button>
          <button onClick="{{ goHow }}" style="background:none; border:none; cursor:pointer; font-family:inherit; font-size:15px; font-weight:500; color:#C2CFE4; padding:0;">How it works</button>
          <button onClick="{{ goTech }}" style="background:none; border:none; cursor:pointer; font-family:inherit; font-size:15px; font-weight:500; color:#C2CFE4; padding:0;">Technology</button>
