      <div>
        <div style="display:flex; align-items:center; gap:11px; margin-bottom:14px;">
          <span style="width:34px; height:34px; border-radius:10px; background:#243355; display:flex; align-items:center; justify-content:center;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M2 12h3.5l2-6 3.2 13 3-9 2.3 4.5H22" stroke="#7CF0B7" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
          <span style="font-size:20px; font-weight:800; color:#fff;">Cadence</span>
        </div>
        <div style="font-size:15px; font-weight:500; color:#8597B5; max-width:300px; line-height:1.5;">Movement-aware medication timing for people living with Parkinson's.</div>
