  <!-- ============================================================ HOW IT WORKS ============================================================ -->
  <sc-if value="{{ isHow }}" hint-placeholder-val="{{ false }}">
  <div style="max-width:1200px; margin:0 auto; padding:64px 32px 30px; text-align:center;">
    <div style="font-size:15px; font-weight:800; letter-spacing:1.6px; color:{{ accent }}; margin-bottom:14px;">HOW IT WORKS</div>
    <h1 style="font-size: clamp(32px,6vw,54px); line-height: 1.08; font-weight: 800; letter-spacing: -1.4px; margin: 0 0 18px; font-family: newsreader serif; font-style: italic">Three steps, all day long.</h1>
    <p style="font-size:20px; line-height:1.55; font-weight:500; color:#3A4A66; max-width:620px; margin:0 auto;">Cadence turns continuous movement data into two early warnings, the next off window and the next freeze, each with one clear action, no diary or guesswork.</p>
  </div>
  <div style="max-width:1200px; margin:0 auto; padding:40px 32px;">
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:26px;" data-stack="1">
      <div style="background:#fff; border:1px solid #ECF0F7; border-radius:28px; padding:34px 30px; box-shadow:0 14px 34px rgba(28,46,92,0.06);">
        <div style="width:60px; height:60px; border-radius:18px; background:#E7F4EC; display:flex; align-items:center; justify-content:center; margin-bottom:22px;"><svg width="30" height="30" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="#1F8A5B" stroke-width="2"></circle><circle cx="12" cy="12" r="2.6" fill="#1F8A5B"></circle></svg></div>
        <div style="font-size:14px; font-weight:800; color:#A9B4C9; margin-bottom:8px;">01</div>
        <h3 style="font-size:25px; font-weight:800; letter-spacing:-0.4px; margin:0 0 10px;">Wear the sensor</h3>
        <p style="font-size:17px; line-height:1.55; font-weight:500; color:#536084; margin:0;">A discreet wrist and ankle band read your movement state continuously, no buttons, no logging. They just know when you're on and when you're slipping.</p>
      </div>
      <div style="background:#fff; border:1px solid #ECF0F7; border-radius:28px; padding:34px 30px; box-shadow:0 14px 34px rgba(28,46,92,0.06);">
        <div style="width:60px; height:60px; border-radius:18px; background:#FBF1E1; display:flex; align-items:center; justify-content:center; margin-bottom:22px;"><svg width="30" height="30" viewBox="0 0 24 24" fill="none"><path d="M3 14l5-6 4 4 5-7 4 5" stroke="#B9700F" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
        <div style="font-size:14px; font-weight:800; color:#A9B4C9; margin-bottom:8px;">02</div>
        <h3 style="font-size:25px; font-weight:800; letter-spacing:-0.4px; margin:0 0 10px;">See your forecast</h3>
        <p style="font-size:17px; line-height:1.55; font-weight:500; color:#536084; margin:0;">Cadence predicts when an off window is likely, usually before you feel it, so wearing-off becomes something you see coming, not a surprise.</p>
      </div>
      <div style="background:#fff; border:1px solid #ECF0F7; border-radius:28px; padding:34px 30px; box-shadow:0 14px 34px rgba(28,46,92,0.06);">
