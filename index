<style>
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; }
  @keyframes cadPulse { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.7); opacity: 0; } }
  @keyframes cadFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
  @keyframes bandSway { 0%,100% { transform: rotateY(-26deg) rotateX(8deg) translateY(0); } 50% { transform: rotateY(26deg) rotateX(8deg) translateY(-14px); } }
  @keyframes glowPulse { 0%,100% { opacity:0.55; } 50% { opacity:1; } }
  @keyframes cadReveal { from { opacity: 0; transform: translateY(34px); } to { opacity: 1; transform: none; } }
  @keyframes cadBlink { 0%,49% { opacity: 1; } 50%,100% { opacity: 0.18; } }
  @keyframes cadShimmer { 0% { background-position: 0% 0; } 100% { background-position: 200% 0; } }
  @keyframes cadMeterPulse { 0% { box-shadow: 0 0 0 0 rgba(47,87,230,0.45); } 70%,100% { box-shadow: 0 0 0 13px rgba(47,87,230,0); } }
  [data-reveal] { opacity: 0; transform: translateY(36px); transition: opacity 0.8s cubic-bezier(0.22,0.61,0.36,1), transform 0.8s cubic-bezier(0.22,0.61,0.36,1); will-change: opacity, transform; }
  [data-reveal="in"] { opacity: 1; transform: none; }
  [data-site-root] button { transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease; }
  [data-site-root] input::placeholder, [data-site-root] textarea::placeholder { color: #8A96B0; }
  @media (prefers-reduced-motion: reduce) { [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; } [data-site-root] * { animation: none !important; } }
  /* ---------- responsive ---------- */
  [data-navtoggle] { display: none; }
  [data-hamburger-bar] { transition: transform 0.32s cubic-bezier(0.22,0.61,0.36,1), opacity 0.2s ease, width 0.25s ease; transform-origin: center; }
  [data-navtoggle][data-open="true"] [data-hamburger-bar]:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  [data-navtoggle][data-open="true"] [data-hamburger-bar]:nth-child(2) { opacity: 0; transform: scaleX(0); }
  [data-navtoggle][data-open="true"] [data-hamburger-bar]:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
  [data-mobile-overlay] { position: fixed; inset: 0; background: rgba(16,24,45,0.32); opacity: 0; visibility: hidden; pointer-events: none; backdrop-filter: blur(0px); -webkit-backdrop-filter: blur(0px); transition: opacity 0.28s ease, backdrop-filter 0.28s ease, -webkit-backdrop-filter 0.28s ease, visibility 0s linear 0.28s; z-index: 45; }
  [data-mobile-overlay][data-open="true"] { opacity: 1; visibility: visible; pointer-events: auto; backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px); transition: opacity 0.28s ease, backdrop-filter 0.28s ease, -webkit-backdrop-filter 0.28s ease, visibility 0s linear 0s; }
  @media (min-width: 761px) { [data-mobile-overlay] { display: none; } }
  @media (max-width: 980px) {
    [data-stack] { grid-template-columns: 1fr !important; gap: 24px !important; }
    [data-quad] { grid-template-columns: 1fr 1fr !important; }
  }
  @media (max-width: 760px) {
    [data-navtoggle] { display: flex !important; }
    [data-navlinks] { display: flex !important; position: absolute; top: calc(100% + 14px); left: 0; right: 0; flex-direction: column; align-items: stretch !important; background: #fff; border-radius: 20px; box-shadow: 0 24px 50px rgba(28,46,92,0.20); padding: 10px; gap: 2px; z-index: 60; opacity: 0; transform: translateY(-10px) scale(0.97); pointer-events: none; visibility: hidden; transition: opacity 0.22s cubic-bezier(0.22,0.61,0.36,1), transform 0.22s cubic-bezier(0.22,0.61,0.36,1), visibility 0s linear 0.22s; }
    [data-navlinks][data-open="true"] { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; visibility: visible; transition: opacity 0.26s cubic-bezier(0.22,0.61,0.36,1), transform 0.26s cubic-bezier(0.22,0.61,0.36,1), visibility 0s linear 0s; }
    [data-navlinks] > button { width: 100%; text-align: left; padding: 15px 18px !important; margin-left: 0 !important; border-radius: 13px !important; }
    [data-navlinks] > button:last-child { margin-top: 6px !important; text-align: center; }
    [data-quad] { grid-template-columns: 1fr !important; }
    [data-roadmap-row] { grid-template-columns: 72px 1fr !important; gap: 16px !important; }
    [data-pad] { padding-left: 22px !important; padding-right: 22px !important; }
  }
</style>
</helmet>

