  <!-- ============================================================ HOME ============================================================ -->
  <sc-if value="{{ isHome }}" hint-placeholder-val="{{ true }}">
  <div style="max-width:1200px; margin:0 auto; padding:60px 32px 56px; display:grid; grid-template-columns:1.05fr 0.95fr; gap:40px; align-items:center; position:relative;" data-stack="1" data-pad="1">
    <div style="position:absolute; top:-40px; left:-160px; width:520px; height:520px; border-radius:50%; background:radial-gradient(circle, rgba(47,87,230,0.10), rgba(47,87,230,0) 68%); pointer-events:none;"></div>
    <div style="position:relative;">
      <div style="display:inline-flex; align-items:center; gap:9px; background:#E7F4EC; padding:8px 15px; border-radius:30px; margin-bottom:24px;">
        <span style="position:relative; width:9px; height:9px;"><span style="position:absolute; inset:0; border-radius:50%; background:#1F8A5B; animation:cadPulse 2.4s ease-out infinite;"></span><span style="position:relative; display:block; width:9px; height:9px; border-radius:50%; background:#1F8A5B;"></span></span>
        <span style="font-size: 20px; font-weight: 700; color: #15724A">For people living with Parkinson's</span>
      </div>
      <h1 style="font-size:clamp(34px,7vw,62px); line-height:1.04; font-weight:800; letter-spacing:-1.8px; margin:0 0 22px;">Stay ahead of<br>every <span style="font-style:italic; font-family:'Newsreader',serif; font-weight:600; color:{{ accent }};">off</span> period.</h1>
      <p style="font-size:21px; line-height:1.55; font-weight:500; color:#3A4A66; max-width:480px; margin:0 0 34px;">Cadence learns your rhythm and forecasts the two moments Parkinson's steals, the next off window and the next freeze, then acts before either lands: a dose nudge on the wrist, a rhythm cue on the ankle.</p>
      <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
