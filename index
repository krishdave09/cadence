      <div style="position:absolute; top:-120px; left:-80px; width:340px; height:340px; border-radius:50%; background:radial-gradient(circle, rgba(124,240,183,0.13), rgba(124,240,183,0) 70%); pointer-events:none;"></div>
      <div style="position:absolute; bottom:-140px; right:-60px; width:380px; height:380px; border-radius:50%; background:radial-gradient(circle, rgba(47,87,230,0.30), rgba(47,87,230,0) 70%); pointer-events:none;"></div>
      <div style="position:relative;">
        <div style="font-size:14px; font-weight:800; letter-spacing:1.6px; color:#7CF0B7; margin-bottom:14px;">JOIN THE WAITLIST</div>
        <h2 style="font-size:clamp(28px,5vw,44px); line-height:1.1; font-weight:800; letter-spacing:-1.1px; color:#fff; margin:0 0 14px; font-family:'Newsreader',serif; font-style:italic;">Be first in line when Cadence is ready.</h2>
        <p style="font-size:18px; line-height:1.55; font-weight:500; color:#A9B7D0; max-width:480px; margin:0 auto 30px;">Early access opens in waves. Leave your email and we'll reach out when it's your turn.</p>
        <div style="display:flex; gap:12px; max-width:520px; margin:0 auto; flex-wrap:wrap; justify-content:center;">
          <input value="{{ email }}" onInput="{{ setEmail }}" placeholder="you@email.com" style="flex:1; min-width:220px; min-height:58px; padding:0 22px; font-family:inherit; font-size:17px; font-weight:500; color:#fff; background:#243355; border:2px solid #33456B; border-radius:16px; outline:none;" style-focus="border-color:#2F57E6">
          <button onClick="{{ submit }}" style="min-height:58px; padding:0 28px; background:#2F57E6; border:none; border-radius:16px; font-family:inherit; font-size:17px; font-weight:700; color:#fff; cursor:pointer; box-shadow:0 14px 30px rgba(47,87,230,0.35);" style-hover="background:#2448C4" style-active="transform:scale(0.97)">{{ ctaLabel }}</button>
