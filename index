        <button onClick="{{ goHow }}" style="font-size:18px; font-weight:700; color:#16203A; background:#fff; cursor:pointer; font-family:inherit; padding:18px 26px; border-radius:18px; border:2px solid #DCE3EF;">See how it works</button>
