      </div>
      <textarea value="{{ cMsg }}" onInput="{{ setCMsg }}" placeholder="tell us a little about what you need…" rows="5" style="width:100%; padding:16px 20px; font-family:inherit; font-size:17px; font-weight:500; color:#16203A; background:#FBFCFE; border:2px solid #DCE3EF; border-radius:16px; outline:none; resize:vertical; min-height:130px;" style-focus="border-color:#2F57E6"></textarea>
      <div style="display:flex; align-items:center; gap:16px; margin-top:20px; flex-wrap:wrap;">
        <button onClick="{{ sendMessage }}" style="min-height:58px; padding:0 30px; background:#16203A; border:none; border-radius:16px; font-family:inherit; font-size:17px; font-weight:700; color:#fff; cursor:pointer;" style-hover="background:#222F4D" style-active="transform:scale(0.97)">{{ sendLabel }}</button>
