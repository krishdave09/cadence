            <div style="height:69%; background:#8A96B0; border-radius:12px 12px 4px 4px;"></div>
          </div>
          <div onClick="{{ ladderClick1 }}" style="flex:1; display:flex; flex-direction:column; justify-content:flex-end; height:100%; cursor:pointer; transition:transform 0.18s;" style-hover="transform:translateY(-4px)">
